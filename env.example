# HaulDirect Backend — Environment Variables
# Copy this file to a file named exactly: .env
# NEVER commit .env to Git — add it to .gitignore
# NEVER put these values in your React frontend code

# -----------------------------------------------
# FMCSA QCMobile API — your key is set below
# -----------------------------------------------
FMCSA_API_KEY=eeb7553869b3de8e716c28bd9a8fbedc7b7a02ed

# -----------------------------------------------
# SaferWatch (optional — adds real insurance $$ amounts)
# -----------------------------------------------
SAFERWATCH_API_KEY=your_saferwatch_key_here

# -----------------------------------------------
# Stripe (for subscriptions + QuickPay)
# -----------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------
# Server config
# -----------------------------------------------
PORT=4000
ALLOWED_ORIGIN=https://yourdomain.com
